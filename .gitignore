# dependencies
node_modules

# misc
.DS_Store
.idea
.eslintcache

# npm/js ignores
tmp
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# Various temp files
*.swp

# Binaries
/bin/

# Built JS
dist/

# Python Lambda build artifacts (ignore contents but keep directories)
python/virus-scan/clamAV-def/*
!python/virus-scan/clamAV-def/.gitkeep
python/virus-scan/deploy/*
!python/virus-scan/deploy/.gitkeep
python/virus-scan/layer/*
!python/virus-scan/layer/.gitkeep
